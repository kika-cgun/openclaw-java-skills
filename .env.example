# Copy this file to .env and fill in your values.
# cp .env.example .env
# NEVER commit .env to git.

# ─── Database ─────────────────────────────────────────────────────────────────
DB_USERNAME=openclaw
DB_PASSWORD=change_me

# ─── OpenRouter AI ────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...

# Model options (free tier on OpenRouter):
#   stepfun/step-3-5-flash:free      ← default, fast & free
#   qwen/qwen3-235b-a22b:free        ← Qwen 3.6 Plus equivalent, better reasoning
#   qwen/qwen3-30b-a3b:free          ← lighter Qwen, faster
#   anthropic/claude-sonnet-4-5      ← best quality, paid
OPENROUTER_MODEL=stepfun/step-3-5-flash:free

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:AAF...
TELEGRAM_CHAT_ID=-100123456789

# ─── REST API ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
APP_API_KEY=change_me

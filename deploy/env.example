# Copy this file to /etc/openclaw/env on the VPS and fill in the values.
# chmod 600 /etc/openclaw/env
# chown openclaw:openclaw /etc/openclaw/env

DB_USERNAME=openclaw
DB_PASSWORD=change_me

OPENROUTER_API_KEY=sk-or-...
# Model options (free tier):
#   stepfun/step-3-5-flash:free   ← fast & free (default)
#   qwen/qwen3-235b-a22b:free     ← Qwen 3.6 Plus equivalent
#   anthropic/claude-sonnet-4-5   ← paid, best quality
OPENROUTER_MODEL=stepfun/step-3-5-flash:free

# Optional. Keep false for OpenClaw plugin-only mode.
APP_TELEGRAM_ENABLED=false
# Required only when APP_TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=123456789:AAF...
TELEGRAM_CHAT_ID=-100123456789

# No default — must be set. Use a strong random value.
# openssl rand -hex 32
APP_API_KEY=change_me

# OpenClaw plugin env vars (set in OpenClaw runtime config, not backend app env)
# CAREER_API_BASE_URL should point to the locally exposed backend port
# (for docker-compose local binding: http://127.0.0.1:18080)
# CAREER_API_KEY should match APP_API_KEY
CAREER_API_BASE_URL=http://127.0.0.1:18080
CAREER_API_KEY=change_me
